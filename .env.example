CV_OBJECT_STORE_SECRET_KEY=commercevision-secret
CV_OBJECT_STORE_BUCKET=task-assets
CV_CORS_ORIGINS=["http://localhost:13000"]
CV_MCP_TRANSPORT=streamable-http
