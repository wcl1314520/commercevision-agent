CV_ENVIRONMENT=local
CV_LOG_LEVEL=INFO
CV_PYPI_INDEX_URL=https://pypi.org/simple
# CV_SECRETS_DIR=C:\path\to\runtime-secrets
CV_READINESS_PROBE_EXTERNAL=false
